<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AMG Produções — O Futuro dos Eventos</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap');

  :root {
    --gold: #C9A84C;
    --gold-light: #F0D080;
    --gold-dim: #8B6E2A;
    --black: #050505;
    --deep: #0A0A0F;
    --panel: rgba(12,12,18,0.92);
    --text: #F0EDE4;
    --muted: rgba(240,237,228,0.45);
    --border: rgba(201,168,76,0.18);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--black);
    color: var(--text);
    font-family: 'Space Grotesk', sans-serif;
    overflow-x: hidden;
    cursor: none;
  }

  /* CUSTOM CURSOR */
  #cursor {
    position: fixed; width: 10px; height: 10px;
    background: var(--gold); border-radius: 50%;
    pointer-events: none; z-index: 9999;
    transform: translate(-50%,-50%);
    transition: transform 0.08s, width 0.2s, height 0.2s, background 0.2s;
  }
  #cursor-ring {
    position: fixed; width: 38px; height: 38px;
    border: 1px solid var(--gold); border-radius: 50%;
    pointer-events: none; z-index: 9998;
    transform: translate(-50%,-50%);
    transition: transform 0.18s ease-out, width 0.3s, height 0.3s, opacity 0.3s;
    opacity: 0.5;
  }
  body:hover #cursor { opacity: 1; }

  /* INTRO SCREEN */
  #intro {
    position: fixed; inset: 0; z-index: 1000;
    background: #000; display: flex; align-items: center; justify-content: center;
    flex-direction: column; gap: 2rem;
    transition: opacity 1.2s ease;
  }
  #intro.out { opacity: 0; pointer-events: none; }

  #logo-reveal {
    opacity: 0; transform: scale(0.7) translateY(20px);
    transition: opacity 1s ease, transform 1s cubic-bezier(0.16,1,0.3,1);
    text-align: center;
    position: relative; z-index: 2;
  }
  #logo-reveal.show { opacity: 1; transform: scale(1) translateY(0); }

  .logo-amg {
    font-family: 'Space Mono', monospace;
    font-size: clamp(4rem, 12vw, 9rem);
    font-weight: 700;
    letter-spacing: 0.3em;
    background: linear-gradient(135deg, var(--gold-dim), var(--gold-light), var(--gold-dim));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 0 40px rgba(201,168,76,0.4));
    animation: floatLogo 4s ease-in-out infinite;
  }

  @keyframes floatLogo {
    0%, 100% { transform: translateY(0) rotateX(0deg); }
    50% { transform: translateY(-12px) rotateX(2deg); }
  }

  .logo-sub {
    font-size: clamp(0.7rem, 2vw, 1rem);
    letter-spacing: 0.6em;
    color: var(--muted);
    text-transform: uppercase;
    margin-top: 0.5rem;
  }

  .intro-tagline {
    font-size: clamp(0.85rem, 2.5vw, 1.1rem);
    color: var(--muted);
    text-align: center;
    max-width: 520px;
    line-height: 1.7;
    padding: 0 2rem;
  }

  .intro-tagline em {
    color: var(--gold); font-style: normal;
  }

  #btn-enter {
    margin-top: 1rem;
    padding: 1rem 3rem;
    background: transparent;
    border: 1px solid var(--gold);
    color: var(--gold);
    font-family: 'Space Mono', monospace;
    font-size: 0.8rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    cursor: none;
    position: relative;
    overflow: hidden;
    transition: color 0.3s, box-shadow 0.3s;
  }
  #btn-enter::before {
    content: ''; position: absolute; inset: 0;
    background: var(--gold); transform: translateX(-101%);
    transition: transform 0.4s cubic-bezier(0.16,1,0.3,1);
    z-index: 0;
  }
  #btn-enter:hover::before { transform: translateX(0); }
  #btn-enter:hover { color: #000; box-shadow: 0 0 40px rgba(201,168,76,0.4); }
  #btn-enter span { position: relative; z-index: 1; }

  /* PARTICLES */
  #particles-canvas {
    position: fixed; inset: 0; z-index: 0; pointer-events: none;
  }

  /* MAIN SITE */
  #site {
    position: relative; z-index: 1;
    opacity: 0; transform: translateY(30px);
    transition: opacity 1s ease, transform 1s ease;
    min-height: 100vh;
  }
  #site.visible { opacity: 1; transform: translateY(0); }

  /* NAV */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 500;
    padding: 1.5rem 4rem;
    display: flex; align-items: center; justify-content: space-between;
    background: linear-gradient(to bottom, rgba(5,5,5,0.95), transparent);
    backdrop-filter: blur(8px);
  }

  .nav-logo {
    font-family: 'Space Mono', monospace;
    font-size: 1.3rem;
    letter-spacing: 0.3em;
    background: linear-gradient(135deg, var(--gold-dim), var(--gold-light));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .nav-links {
    display: flex; gap: 3rem; list-style: none;
  }
  .nav-links a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.78rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    transition: color 0.3s;
    position: relative;
  }
  .nav-links a::after {
    content: ''; position: absolute; bottom: -4px; left: 0;
    width: 0; height: 1px; background: var(--gold);
    transition: width 0.3s;
  }
  .nav-links a:hover { color: var(--gold); }
  .nav-links a:hover::after { width: 100%; }

  .nav-cta {
    padding: 0.6rem 1.8rem;
    border: 1px solid var(--gold);
    color: var(--gold) !important;
    font-size: 0.72rem !important;
    letter-spacing: 0.3em;
    transition: background 0.3s, color 0.3s !important;
  }
  .nav-cta:hover { background: var(--gold) !important; color: #000 !important; }
  .nav-cta::after { display: none !important; }

  /* SECTIONS */
  section {
    position: relative;
    padding: 8rem 4rem;
    max-width: 1400px;
    margin: 0 auto;
  }

  .section-eyebrow {
    font-family: 'Space Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.5em;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    display: flex; align-items: center; gap: 1rem;
  }
  .section-eyebrow::before {
    content: ''; display: block; width: 2rem; height: 1px; background: var(--gold);
  }

  .section-title {
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    background: linear-gradient(135deg, var(--text) 60%, var(--gold));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-lead {
    font-size: 1.05rem;
    color: var(--muted);
    max-width: 600px;
    line-height: 1.8;
    margin-bottom: 3rem;
  }

  /* HERO WORLD */
  #world {
    min-height: 100vh;
    display: flex; align-items: center;
    padding-top: 10rem;
    position: relative;
    overflow: hidden;
  }

  #canvas-3d {
    position: absolute; inset: 0; z-index: 0;
    opacity: 0.8;
  }

  .hero-content {
    position: relative; z-index: 2;
    max-width: 750px;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 5.5rem);
    font-weight: 700;
    line-height: 1.05;
    margin-bottom: 2rem;
  }

  .hero-title .accent {
    background: linear-gradient(135deg, var(--gold-dim), var(--gold-light));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-lead {
    font-size: 1.15rem;
    color: var(--muted);
    line-height: 1.8;
    max-width: 550px;
    margin-bottom: 3rem;
  }

  .hero-buttons { display: flex; gap: 1.5rem; flex-wrap: wrap; }

  .btn-primary {
    padding: 1rem 2.5rem;
    background: var(--gold);
    color: #000;
    border: none;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    cursor: none;
    position: relative;
    overflow: hidden;
    transition: box-shadow 0.3s, transform 0.2s;
    text-decoration: none;
    display: inline-flex; align-items: center; gap: 0.6rem;
  }
  .btn-primary:hover { box-shadow: 0 0 50px rgba(201,168,76,0.5); transform: translateY(-2px); }

  .btn-ghost {
    padding: 1rem 2.5rem;
    background: transparent;
    color: var(--text);
    border: 1px solid rgba(240,237,228,0.25);
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: none;
    transition: border-color 0.3s, color 0.3s;
    text-decoration: none;
    display: inline-flex; align-items: center; gap: 0.6rem;
  }
  .btn-ghost:hover { border-color: var(--gold); color: var(--gold); }

  /* STATS BAR */
  .stats-bar {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 0; border: 1px solid var(--border);
    margin: 0 4rem;
    background: var(--panel);
    backdrop-filter: blur(16px);
  }

  .stat-item {
    padding: 2rem;
    border-right: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }
  .stat-item:last-child { border-right: none; }
  .stat-item::before {
    content: ''; position: absolute; bottom: 0; left: 0; right: 0;
    height: 2px; background: linear-gradient(90deg, var(--gold-dim), var(--gold));
    transform: scaleX(0); transform-origin: left;
    transition: transform 0.6s cubic-bezier(0.16,1,0.3,1);
  }
  .stat-item:hover::before { transform: scaleX(1); }

  .stat-number {
    font-family: 'Space Mono', monospace;
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 700;
    background: linear-gradient(135deg, var(--gold-dim), var(--gold-light));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.3rem;
  }

  .stat-label {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    color: var(--muted);
    text-transform: uppercase;
  }

  /* UNIVERSE CARDS */
  .universe-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1px;
    border: 1px solid var(--border);
    overflow: hidden;
  }

  .universe-card {
    background: var(--panel);
    padding: 2.5rem;
    position: relative;
    overflow: hidden;
    cursor: none;
    transition: background 0.4s;
  }
  .universe-card::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(circle at 30% 50%, rgba(201,168,76,0.07), transparent 60%);
    opacity: 0; transition: opacity 0.4s;
  }
  .universe-card:hover { background: rgba(20,18,12,0.97); }
  .universe-card:hover::before { opacity: 1; }

  .card-icon {
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
    display: block;
    filter: grayscale(0.3);
    transition: filter 0.3s, transform 0.3s;
  }
  .universe-card:hover .card-icon { filter: grayscale(0); transform: scale(1.1); }

  .card-title {
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 0.8rem;
    color: var(--text);
  }

  .card-desc {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.7;
  }

  .card-arrow {
    position: absolute; bottom: 2rem; right: 2rem;
    color: var(--gold);
    font-size: 1.2rem;
    opacity: 0; transition: opacity 0.3s, transform 0.3s;
    transform: translateX(-8px);
  }
  .universe-card:hover .card-arrow { opacity: 1; transform: translateX(0); }

  /* AI SECTION */
  #ai-section {
    padding: 8rem 4rem;
  }

  .ai-container {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 4rem; align-items: center;
    max-width: 1400px; margin: 0 auto;
  }

  .ai-chat {
    background: var(--panel);
    border: 1px solid var(--border);
    padding: 2rem;
    font-family: 'Space Mono', monospace;
    font-size: 0.82rem;
    position: relative;
    overflow: hidden;
    min-height: 460px;
  }

  .ai-chat::before {
    content: 'AMG INTELLIGENCE — AI PRODUCER';
    display: block;
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    color: var(--gold);
    padding-bottom: 1.2rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 1.5rem;
  }

  .chat-msg {
    margin-bottom: 1.2rem;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .chat-msg.visible { opacity: 1; transform: translateY(0); }

  .msg-user {
    color: var(--muted);
  }
  .msg-user::before { content: '[ CLIENTE ] → '; color: var(--gold-dim); }
  .msg-ai { color: var(--text); }
  .msg-ai::before { content: '[ AMG AI ] → '; color: var(--gold); }
  .msg-system {
    color: var(--gold-dim);
    font-size: 0.72rem;
    padding-left: 1rem;
    border-left: 1px solid var(--gold-dim);
  }

  .ai-concept-card {
    background: rgba(201,168,76,0.05);
    border: 1px solid rgba(201,168,76,0.2);
    padding: 1.2rem;
    margin-top: 1rem;
    opacity: 0; transition: opacity 0.8s ease;
  }
  .ai-concept-card.visible { opacity: 1; }
  .ai-concept-card .concept-title {
    color: var(--gold);
    font-size: 0.9rem;
    font-weight: 700;
    margin-bottom: 0.8rem;
  }
  .ai-concept-card .concept-row {
    display: flex; justify-content: space-between;
    border-bottom: 1px solid rgba(201,168,76,0.1);
    padding: 0.4rem 0;
    font-size: 0.75rem;
    color: var(--muted);
  }
  .ai-concept-card .concept-row span:last-child { color: var(--text); }

  .ai-input-row {
    display: flex; gap: 0; margin-top: 1.5rem;
    border: 1px solid var(--border);
  }
  #ai-input {
    flex: 1;
    background: transparent;
    border: none;
    color: var(--text);
    font-family: 'Space Mono', monospace;
    font-size: 0.78rem;
    padding: 0.8rem 1rem;
    outline: none;
  }
  #ai-input::placeholder { color: rgba(240,237,228,0.2); }
  #ai-send {
    background: var(--gold);
    border: none;
    color: #000;
    padding: 0.8rem 1.2rem;
    cursor: none;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    transition: opacity 0.3s;
  }
  #ai-send:hover { opacity: 0.85; }

  /* EVENT BUILDER */
  #builder-section {
    padding: 8rem 4rem;
    background: rgba(201,168,76,0.015);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .builder-inner {
    max-width: 1400px; margin: 0 auto;
  }

  .builder-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 4rem; align-items: start;
    margin-top: 3rem;
  }

  .builder-controls { display: flex; flex-direction: column; gap: 2rem; }

  .builder-group-label {
    font-family: 'Space Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.4em;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .builder-options {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.8rem;
  }

  .builder-opt {
    background: var(--panel);
    border: 1px solid var(--border);
    padding: 1rem 0.8rem;
    text-align: center;
    cursor: none;
    transition: all 0.3s;
    font-size: 0.78rem;
    color: var(--muted);
    position: relative;
    overflow: hidden;
  }
  .builder-opt::before {
    content: ''; position: absolute; inset: 0;
    background: var(--gold); opacity: 0; transition: opacity 0.3s; z-index: 0;
  }
  .builder-opt span { position: relative; z-index: 1; }
  .builder-opt:hover { color: #000; }
  .builder-opt:hover::before { opacity: 1; }
  .builder-opt.selected { border-color: var(--gold); color: var(--gold); background: rgba(201,168,76,0.1); }

  .builder-preview {
    background: var(--panel);
    border: 1px solid var(--border);
    aspect-ratio: 16/10;
    display: flex; align-items: center; justify-content: center;
    flex-direction: column; gap: 1.5rem;
    position: relative;
    overflow: hidden;
    transition: all 0.5s ease;
  }

  .preview-stage {
    width: 70%; height: 3rem;
    background: rgba(201,168,76,0.15);
    border-top: 2px solid var(--gold);
    transition: all 0.5s;
    position: relative;
  }

  .preview-lights {
    display: flex; gap: 0.8rem;
  }
  .plight {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--gold); opacity: 0.6;
    transition: all 0.4s;
    box-shadow: 0 0 8px var(--gold);
  }

  .preview-label {
    font-family: 'Space Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    color: var(--gold);
    text-transform: uppercase;
    margin-top: 0.5rem;
  }

  .preview-vibe {
    font-size: 0.75rem;
    color: var(--muted);
    letter-spacing: 0.15em;
    text-align: center;
    padding: 0 2rem;
    line-height: 1.6;
  }

  /* CINEMA MODE */
  #cinema-section { padding: 8rem 4rem; }

  .cinema-inner {
    max-width: 1400px; margin: 0 auto;
  }

  .cinema-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;
    margin-top: 3rem;
  }

  .cinema-card {
    background: var(--panel);
    border: 1px solid var(--border);
    aspect-ratio: 16/9;
    position: relative;
    overflow: hidden;
    cursor: none;
    transition: transform 0.4s, box-shadow 0.4s;
  }
  .cinema-card:hover { transform: scale(1.02); box-shadow: 0 20px 60px rgba(0,0,0,0.5); }

  .cinema-card-bg {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 4rem;
    opacity: 0.1; transition: opacity 0.4s;
  }
  .cinema-card:hover .cinema-card-bg { opacity: 0.18; }

  .cinema-card-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(5,5,5,0.9) 0%, transparent 60%);
  }

  .cinema-card-content {
    position: absolute; bottom: 1.5rem; left: 1.5rem; right: 1.5rem;
  }
  .cinema-card-title {
    font-size: 1rem; font-weight: 600; margin-bottom: 0.3rem;
  }
  .cinema-card-sub { font-size: 0.72rem; color: var(--muted); letter-spacing: 0.15em; }

  .cinema-play {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    width: 48px; height: 48px;
    border: 1px solid rgba(201,168,76,0.5);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: var(--gold);
    font-size: 1rem;
    opacity: 0; transition: opacity 0.3s;
  }
  .cinema-card:hover .cinema-play { opacity: 1; }

  /* TRANSFORMADOR */
  #transform-section { padding: 8rem 4rem; }

  .transform-inner {
    max-width: 1400px; margin: 0 auto;
  }

  .transform-demo {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 1.5rem; margin-top: 3rem;
  }

  .transform-panel {
    background: var(--panel);
    border: 1px solid var(--border);
    aspect-ratio: 4/3;
    display: flex; align-items: center; justify-content: center;
    flex-direction: column;
    gap: 1rem;
    position: relative;
    overflow: hidden;
    cursor: none;
    transition: all 0.6s ease;
  }

  .transform-label {
    position: absolute; top: 1.2rem; left: 1.5rem;
    font-family: 'Space Mono', monospace;
    font-size: 0.6rem; letter-spacing: 0.4em;
    color: var(--muted); text-transform: uppercase;
  }

  .before-content {
    font-size: 0.85rem;
    color: rgba(240,237,228,0.2);
    text-align: center;
  }

  .after-content {
    text-align: center;
    padding: 2rem;
    opacity: 0;
    transition: opacity 0.8s ease;
  }

  .after-content.reveal { opacity: 1; }

  .after-elements {
    display: flex; flex-wrap: wrap; gap: 0.5rem;
    justify-content: center; margin-top: 1rem;
  }

  .after-element {
    padding: 0.3rem 0.8rem;
    border: 1px solid rgba(201,168,76,0.3);
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: var(--gold);
    background: rgba(201,168,76,0.06);
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  .after-element.show { opacity: 1; transform: translateY(0); }

  .transform-btn {
    display: block; width: 100%;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--muted);
    font-family: 'Space Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    padding: 1.2rem;
    cursor: none;
    transition: all 0.3s;
    margin-top: 1.5rem;
    text-align: center;
  }
  .transform-btn:hover { border-color: var(--gold); color: var(--gold); }

  /* AREA CLIENTE */
  #cliente-section { padding: 8rem 4rem; }

  .cliente-inner {
    max-width: 1400px; margin: 0 auto;
  }

  .timeline {
    position: relative; margin-top: 3rem;
    padding-left: 2rem;
  }
  .timeline::before {
    content: ''; position: absolute; left: 0; top: 0; bottom: 0;
    width: 1px; background: linear-gradient(to bottom, var(--gold), transparent);
  }

  .timeline-item {
    position: relative; padding: 0 0 3rem 2.5rem;
    opacity: 0; transform: translateX(-20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .timeline-item.visible { opacity: 1; transform: translateX(0); }
  .timeline-item::before {
    content: ''; position: absolute; left: -4.5px; top: 4px;
    width: 9px; height: 9px; border-radius: 50%;
    background: var(--gold);
    box-shadow: 0 0 12px var(--gold);
  }

  .timeline-date {
    font-family: 'Space Mono', monospace;
    font-size: 0.65rem; letter-spacing: 0.3em;
    color: var(--gold-dim); margin-bottom: 0.5rem;
  }

  .timeline-title {
    font-size: 1rem; font-weight: 600; margin-bottom: 0.4rem;
  }

  .timeline-desc {
    font-size: 0.82rem; color: var(--muted); line-height: 1.6;
  }

  .timeline-badge {
    display: inline-block;
    padding: 0.15rem 0.6rem;
    background: rgba(201,168,76,0.1);
    border: 1px solid rgba(201,168,76,0.3);
    color: var(--gold);
    font-size: 0.62rem; letter-spacing: 0.2em;
    text-transform: uppercase; margin-top: 0.5rem;
  }

  /* FOOTER */
  footer {
    border-top: 1px solid var(--border);
    padding: 4rem;
    display: grid; grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 3rem;
    max-width: 1400px; margin: 0 auto;
  }

  .footer-brand .logo-amg { font-size: 2rem; }
  .footer-desc {
    font-size: 0.82rem; color: var(--muted); line-height: 1.7;
    margin-top: 1rem; max-width: 280px;
  }

  .footer-heading {
    font-family: 'Space Mono', monospace;
    font-size: 0.65rem; letter-spacing: 0.4em;
    color: var(--gold); text-transform: uppercase;
    margin-bottom: 1.2rem;
  }

  .footer-links { list-style: none; display: flex; flex-direction: column; gap: 0.7rem; }
  .footer-links a {
    color: var(--muted); text-decoration: none;
    font-size: 0.83rem; transition: color 0.3s;
  }
  .footer-links a:hover { color: var(--gold); }

  .footer-bottom {
    border-top: 1px solid var(--border);
    padding: 1.5rem 4rem;
    display: flex; justify-content: space-between; align-items: center;
    max-width: 1400px; margin: 0 auto;
    font-size: 0.72rem; color: var(--muted);
    font-family: 'Space Mono', monospace;
  }

  /* DIVIDER LINE */
  .divider {
    height: 1px; background: linear-gradient(90deg, transparent, var(--border), transparent);
    max-width: 1400px; margin: 0 auto;
  }

  /* SCROLL REVEAL */
  .reveal {
    opacity: 0; transform: translateY(30px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  /* SCROLLBAR */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: var(--black); }
  ::-webkit-scrollbar-thumb { background: var(--gold-dim); }

  /* SCAN LINE */
  body::after {
    content: ''; position: fixed; inset: 0; pointer-events: none;
    background: repeating-linear-gradient(
      0deg,
      transparent 0px, transparent 2px,
      rgba(0,0,0,0.03) 2px, rgba(0,0,0,0.03) 4px
    );
    z-index: 9990;
  }

  @media (max-width: 900px) {
    nav { padding: 1.2rem 1.5rem; }
    .nav-links { display: none; }
    section { padding: 4rem 1.5rem; }
    .stats-bar { grid-template-columns: 1fr 1fr; margin: 0 1.5rem; }
    .ai-container, .builder-grid, .transform-demo, footer { grid-template-columns: 1fr; }
    .cinema-grid { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>

<div id="cursor"></div>
<div id="cursor-ring"></div>

<canvas id="particles-canvas"></canvas>

<div id="intro">
  <div id="logo-reveal">
    <div class="logo-amg">AMG</div>
    <div class="logo-sub">Produções</div>
  </div>
  <p class="intro-tagline" id="intro-tagline" style="opacity:0; transition: opacity 1s ease 0.5s;">
    O futuro dos eventos começa <em>antes da primeira pessoa chegar.</em>
  </p>
  <button id="btn-enter" style="opacity:0; transition: opacity 0.8s ease 0.8s;">
    <span>▶ Iniciar Experiência</span>
  </button>
</div>

<div id="site">

  <nav>
    <div class="nav-logo">AMG</div>
    <ul class="nav-links">
      <li><a href="#world">Universo</a></li>
      <li><a href="#ai-section">Inteligência</a></li>
      <li><a href="#builder-section">Builder</a></li>
      <li><a href="#cinema-section">Cinema</a></li>
      <li><a href="#cliente-section">Área Cliente</a></li>
      <li><a href="#contato" class="nav-cta">Contratar</a></li>
    </ul>
  </nav>

  <section id="world">
    <canvas id="canvas-3d"></canvas>
    <div class="hero-content">
      <div class="section-eyebrow">Bem-vindo ao universo AMG</div>
      <h1 class="hero-title">
        Eventos que<br><span class="accent">transcendem</span><br>o possível.
      </h1>
      <p class="hero-lead">
        Não criamos eventos. Criamos universos. Cada projeto é uma obra de arte vivida em tempo real — onde tecnologia, luz, som e emoção se fundem em experiências inesquecíveis.
      </p>
      <div class="hero-buttons">
        <a href="#ai-section" class="btn-primary">Explorar o universo →</a>
        <a href="#builder-section" class="btn-ghost">Montar meu evento</a>
      </div>
    </div>
  </section>

  <div class="stats-bar reveal">
    <div class="stat-item">
      <div class="stat-number" data-target="847">0</div>
      <div class="stat-label">Eventos realizados</div>
    </div>
    <div class="stat-item">
      <div class="stat-number" data-target="12">0</div>
      <div class="stat-label">Anos de excelência</div>
    </div>
    <div class="stat-item">
      <div class="stat-number" data-target="98">0</div>
      <div class="stat-label">% satisfação</div>
    </div>
    <div class="stat-item">
      <div class="stat-number" data-target="340">0</div>
      <div class="stat-label">Profissionais na equipe</div>
    </div>
  </div>

  <div style="height:6rem"></div>

  <section id="universe" class="reveal">
    <div class="section-eyebrow">O mundo AMG</div>
    <h2 class="section-title">Entre no universo.<br>Explore cada dimensão.</h2>
    <p class="section-lead">Cada área da AMG é um mundo próprio. Mergulhe em cada um e descubra como transformamos o ordinário em extraordinário.</p>

    <div class="universe-grid">
      <div class="universe-card">
        <span class="card-icon">🎤</span>
        <div class="card-title">Eventos & Shows</div>
        <div class="card-desc">Da concepção ao último aplaudir. Shows, festivais, lançamentos e celebrações que ficam na memória por décadas.</div>
        <div class="card-arrow">→</div>
      </div>
      <div class="universe-card">
        <span class="card-icon">💡</span>
        <div class="card-title">Iluminação Arquitetural</div>
        <div class="card-desc">Luz como linguagem. Transformamos ambientes com design luminoso que conta histórias e cria atmosferas únicas.</div>
        <div class="card-arrow">→</div>
      </div>
      <div class="universe-card">
        <span class="card-icon">🎥</span>
        <div class="card-title">Produção Audiovisual</div>
        <div class="card-desc">Câmeras, telões, transmissões ao vivo e direção cinematográfica. Seu evento visto por todos, em qualidade de cinema.</div>
        <div class="card-arrow">→</div>
      </div>
      <div class="universe-card">
        <span class="card-icon">🏢</span>
        <div class="card-title">Eventos Corporativos</div>
        <div class="card-desc">Convenções, lançamentos de produtos e experiências para marcas que exigem o melhor. Profissionalismo e impacto máximo.</div>
        <div class="card-arrow">→</div>
      </div>
      <div class="universe-card">
        <span class="card-icon">✨</span>
        <div class="card-title">Experiências Personalizadas</div>
        <div class="card-desc">Casamentos, formaturas, aniversários únicos. Cada detalhe pensado para você. Cada momento, eterno.</div>
        <div class="card-arrow">→</div>
      </div>
      <div class="universe-card" style="background: rgba(201,168,76,0.04); border-color: rgba(201,168,76,0.3);">
        <span class="card-icon">🤖</span>
        <div class="card-title">AMG Intelligence</div>
        <div class="card-desc">Nossa IA cria o conceito do seu evento em segundos. Visuals, paleta, estrutura. O futuro da produção de eventos.</div>
        <div class="card-arrow" style="opacity:1; color: var(--gold);">→</div>
      </div>
    </div>
  </section>

  <div class="divider reveal"></div>

  <div id="ai-section" style="padding: 0 4rem;">
    <div class="ai-container" style="max-width:1400px; margin:0 auto; padding: 8rem 0;">
      <div class="reveal">
        <div class="section-eyebrow">AMG Intelligence</div>
        <h2 class="section-title">Uma IA que<br>pensa em<br>experiências.</h2>
        <p class="section-lead">
          Descreva seu evento. A AMG Intelligence analisa, cria conceitos visuais, define paletas, estrutura técnica e entrega um briefing completo em segundos.
        </p>
        <p style="font-size:0.78rem; color:var(--muted); line-height:1.7;">
          Treinada com milhares de eventos, referências internacionais e a expertise da equipe AMG. Não é uma IA genérica — é uma produtora de eventos digital.
        </p>
      </div>
      <div class="reveal" style="transition-delay:0.2s">
        <div class="ai-chat" id="ai-chat">
          <div class="chat-msg" id="cm1"><span class="msg-user">Quero um casamento elegante para 200 pessoas.</span></div>
          <div class="chat-msg" id="cm2"><span class="msg-ai">Analisando conceito...</span></div>
          <div class="chat-msg" id="cm3"><span class="msg-system">▸ Processando referências de luxo moderno...</span></div>
          <div class="chat-msg" id="cm4"><span class="msg-system">▸ Mapeando paletas cromáticas ideais...</span></div>
          <div class="chat-msg" id="cm5"><span class="msg-system">▸ Configurando estrutura técnica...</span></div>
          <div class="chat-msg" id="cm6"><span class="msg-ai">Conceito criado. Apresentando:</span></div>
          <div class="ai-concept-card" id="concept-card">
            <div class="concept-title">✦ GOLDEN NIGHT EXPERIENCE</div>
            <div class="concept-row"><span>Atmosfera</span><span>Luxo moderno</span></div>
            <div class="concept-row"><span>Paleta</span><span>Preto + dourado + branco</span></div>
            <div class="concept-row"><span>Estrutura</span><span>Palco central + arcos</span></div>
            <div class="concept-row"><span>Iluminação</span><span>Arquitetural + spots</span></div>
            <div class="concept-row"><span>Som</span><span>Sistema premium linear</span></div>
            <div class="concept-row"><span>Capacidade</span><span>200 convidados</span></div>
          </div>
          <div class="ai-input-row" style="margin-top:1.5rem">
            <input type="text" id="ai-input" placeholder="Descreva seu evento..." />
            <button id="ai-send">→</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="divider reveal"></div>

  <div id="builder-section">
    <div class="builder-inner">
      <div class="reveal">
        <div class="section-eyebrow">AMG Event Builder</div>
        <h2 class="section-title">Monte seu evento.<br>Veja acontecer.</h2>
        <p class="section-lead">Escolha cada elemento e assista o ambiente se transformar em tempo real. Esta é a sua pré-visualização do impossível.</p>
      </div>
      <div class="builder-grid">
        <div class="builder-controls reveal">
          <div>
            <div class="builder-group-label">Palco</div>
            <div class="builder-options">
              <div class="builder-opt" data-group="stage" data-val="pequeno"><span>Intimista</span></div>
              <div class="builder-opt selected" data-group="stage" data-val="medio"><span>Médio</span></div>
              <div class="builder-opt" data-group="stage" data-val="grandioso"><span>Grandioso</span></div>
            </div>
          </div>
          <div>
            <div class="builder-group-label">Iluminação</div>
            <div class="builder-options">
              <div class="builder-opt" data-group="light" data-val="elegante"><span>Elegante</span></div>
              <div class="builder-opt selected" data-group="light" data-val="impactante"><span>Impactante</span></div>
              <div class="builder-opt" data-group="light" data-val="festival"><span>Festival</span></div>
            </div>
          </div>
          <div>
            <div class="builder-group-label">Som</div>
            <div class="builder-options">
              <div class="builder-opt" data-group="sound" data-val="social"><span>Social</span></div>
              <div class="builder-opt" data-group="sound" data-val="premium"><span>Premium</span></div>
              <div class="builder-opt selected" data-group="sound" data-val="gigante"><span>Gigante</span></div>
            </div>
          </div>
          <div>
            <div class="builder-group-label">Experiência estimada</div>
            <div id="est-result" style="background:var(--panel); border:1px solid var(--border); padding:1.2rem; font-family:'Space Mono',monospace; font-size:0.75rem; color:var(--muted); line-height:1.8;">
              AMG ESTIMATE<br>
              <span style="color:var(--gold); font-size:0.9rem;">Configurando...</span>
            </div>
          </div>
        </div>
        <div class="builder-preview reveal" id="preview-box" style="transition-delay:0.15s">
          <div class="preview-label" id="preview-label">AMG STAGE — MÉDIO</div>
          <div class="preview-stage" id="preview-stage"></div>
          <div class="preview-lights" id="preview-lights">
            <div class="plight"></div>
            <div class="plight"></div>
            <div class="plight"></div>
            <div class="plight"></div>
            <div class="plight"></div>
          </div>
          <div class="preview-vibe" id="preview-vibe">
            Atmosfera impactante · Som de festival · Palco central com arcos laterais
          </div>
        </div>
      </div>
    </div>
  </div>

  <div id="transform-section">
    <div class="transform-inner">
      <div class="reveal">
        <div class="section-eyebrow">Simulador de Transformação</div>
        <h2 class="section-title">Do vazio à<br>experiência.</h2>
        <p class="section-lead">Veja como a AMG transforma qualquer espaço. Do salão vazio ao evento dos sonhos. Essa é nossa promessa.</p>
      </div>
      <div class="transform-demo">
        <div class="transform-panel reveal" id="before-panel">
          <div class="transform-label">Antes — Espaço original</div>
          <div class="before-content" style="font-size:3rem; opacity:0.15;">🏛️</div>
          <div class="before-content">Salão vazio.<br>Potencial adormecido.</div>
        </div>
        <div class="transform-panel reveal" id="after-panel" style="transition-delay:0.15s; border-color:rgba(201,168,76,0.4);">
          <div class="transform-label" style="color:var(--gold);">Depois — AMG Experience</div>
          <div class="after-content" id="after-content">
            <div style="font-size:2.5rem; margin-bottom:0.5rem;">✨</div>
            <div style="font-size:0.82rem; color:var(--muted); margin-bottom:1rem;">Transformação completa</div>
            <div class="after-elements" id="after-elements">
              <div class="after-element">Palco central</div>
              <div class="after-element">Iluminação arquitetural</div>
              <div class="after-element">Sistema de som</div>
              <div class="after-element">Telões LED</div>
              <div class="after-element">Decoração temática</div>
              <div class="after-element">Estrutura de teto</div>
              <div class="after-element">Carpet red</div>
              <div class="after-element">Lounge VIP</div>
            </div>
          </div>
        </div>
      </div>
      <button class="transform-btn reveal" id="transform-trigger">→ Ativar transformação</button>
    </div>
  </div>

  <div class="divider reveal"></div>

  <div id="cinema-section">
    <div class="cinema-inner">
      <div class="reveal">
        <div class="section-eyebrow">Cinema Mode</div>
        <h2 class="section-title">Cada evento.<br>Um filme.</h2>
        <p class="section-lead">Produzimos eventos que parecem saídos de um roteiro. Direção de arte, fotografia, cinematografia — cada detalhe pensado para emocionar.</p>
      </div>
      <div class="cinema-grid reveal" style="transition-delay:0.1s">
        <div class="cinema-card">
          <div class="cinema-card-bg">💍</div>
          <div class="cinema-card-overlay"></div>
          <div class="cinema-play">▶</div>
          <div class="cinema-card-content">
            <div class="cinema-card-title">Golden Night — Casamento</div>
            <div class="cinema-card-sub">São Paulo · 2024 · 400 convidados</div>
          </div>
        </div>
        <div class="cinema-card">
          <div class="cinema-card-bg">🎸</div>
          <div class="cinema-card-overlay"></div>
          <div class="cinema-play">▶</div>
          <div class="cinema-card-content">
            <div class="cinema-card-title">Eclipse Festival</div>
            <div class="cinema-card-sub">Rio de Janeiro · 2024 · 5.000 pessoas</div>
          </div>
        </div>
        <div class="cinema-card">
          <div class="cinema-card-bg">🏆</div>
          <div class="cinema-card-overlay"></div>
          <div class="cinema-play">▶</div>
          <div class="cinema-card-content">
            <div class="cinema-card-title">Lançamento Corporativo</div>
            <div class="cinema-card-sub">Brasília · 2024 · Transmissão ao vivo</div>
          </div>
        </div>
        <div class="cinema-card">
          <div class="cinema-card-bg">🎓</div>
          <div class="cinema-card-overlay"></div>
          <div class="cinema-play">▶</div>
          <div class="cinema-card-content">
            <div class="cinema-card-title">Formatura Especial</div>
            <div class="cinema-card-sub">Belo Horizonte · 2024 · 800 formandos</div>
          </div>
        </div>
        <div class="cinema-card">
          <div class="cinema-card-bg">🎉</div>
          <div class="cinema-card-overlay"></div>
          <div class="cinema-play">▶</div>
          <div class="cinema-card-content">
            <div class="cinema-card-title">Aniversário Platinum</div>
            <div class="cinema-card-sub">Campinas · 2024 · Experiência VIP</div>
          </div>
        </div>
        <div class="cinema-card" style="border-color:rgba(201,168,76,0.3); display:flex; align-items:center; justify-content:center;">
          <div style="text-align:center; padding:2rem">
            <div style="font-size:2rem; margin-bottom:1rem; color:var(--gold);">+</div>
            <div style="font-size:0.82rem; color:var(--muted); line-height:1.6;">847 eventos realizados. Cada um, único.</div>
            <div style="margin-top:1rem">
              <a href="#contato" class="btn-ghost" style="font-size:0.72rem; padding:0.6rem 1.2rem; cursor:none">Ver portfólio</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="divider reveal"></div>

  <div id="cliente-section">
    <div class="cliente-inner">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:start;">
        <div class="reveal">
          <div class="section-eyebrow">Área Cliente Premium</div>
          <h2 class="section-title">Seu evento.<br>Sua experiência<br>exclusiva.</h2>
          <p class="section-lead">
            Após contratar a AMG, você recebe acesso a um painel exclusivo onde acompanha cada etapa da produção — como nos bastidores de um grande filme.
          </p>
          <a href="#contato" class="btn-primary" style="display:inline-flex">Contratar →</a>
        </div>
        <div class="reveal" style="transition-delay:0.2s">
          <div class="timeline" id="timeline">
            <div class="timeline-item">
              <div class="timeline-date">Semana 1</div>
              <div class="timeline-title">Briefing & Conceito</div>
              <div class="timeline-desc">Sessão de imersão com a equipe AMG. Conceito definido, referências aprovadas, visão alinhada.</div>
              <div class="timeline-badge">✓ Concluído</div>
            </div>
            <div class="timeline-item">
              <div class="timeline-date">Semana 2–3</div>
              <div class="timeline-title">Design & Production</div>
              <div class="timeline-desc">Equipe técnica em ação. Renders 3D, plantas, cronograma detalhado e equipe definida.</div>
              <div class="timeline-badge">→ Em andamento</div>
            </div>
            <div class="timeline-item">
              <div class="timeline-date">Semana 4</div>
              <div class="timeline-title">Aprovações & Ajustes</div>
              <div class="timeline-desc">Você revisa tudo. Aprovações digitais, feedback em tempo real, revisões ilimitadas.</div>
              <div class="timeline-badge">◷ Aguardando</div>
            </div>
            <div class="timeline-item">
              <div class="timeline-date">Dia D</div>
              <div class="timeline-title">O Evento AMG</div>
              <div class="timeline-desc">Nossa equipe assume. Montagem, operação e desmontagem. Você só precisa aparecer e viver.</div>
              <div class="timeline-badge">★ Premium</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="divider reveal"></div>

  <section id="contato" class="reveal">
    <div style="text-align:center; max-width:700px; margin:0 auto;">
      <div class="section-eyebrow" style="justify-content:center;">Vamos criar juntos</div>
      <h2 class="section-title" style="text-align:center;">Pronto para<br>o extraordinário?</h2>
      <p class="section-lead" style="margin:0 auto 3rem; text-align:center;">
        Uma conversa é o começo de tudo. Nosso time responde em até 2 horas em dias úteis.
      </p>
      <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
        <a href="https://wa.me/5511999999999" class="btn-primary">Falar no WhatsApp →</a>
        <a href="mailto:contato@amgproducoes.com.br" class="btn-ghost">Enviar e-mail</a>
      </div>
    </div>
  </section>

  <footer class="reveal">
    <div class="footer-brand">
      <div class="logo-amg">AMG</div>
      <p class="footer-desc">
        A empresa de eventos mais inovadora do Brasil. Tecnologia, luxo e emoção em cada projeto.
      </p>
    </div>
    <div>
      <div class="footer-heading">Serviços</div>
      <ul class="footer-links">
        <li><a href="#">Eventos & Shows</a></li>
        <li><a href="#">Iluminação</a></li>
        <li><a href="#">Audiovisual</a></li>
        <li><a href="#">Corporativo</a></li>
        <li><a href="#">Casamentos</a></li>
      </ul>
    </div>
    <div>
      <div class="footer-heading">Empresa</div>
      <ul class="footer-links">
        <li><a href="#">Sobre a AMG</a></li>
        <li><a href="#">Portfólio</a></li>
        <li><a href="#">Equipe</a></li>
        <li><a href="#">Imprensa</a></li>
      </ul>
    </div>
    <div>
      <div class="footer-heading">Contato</div>
      <ul class="footer-links">
        <li><a href="#">São Paulo, SP</a></li>
        <li><a href="#">contato@amgproducoes.com.br</a></li>
        <li><a href="#">(11) 9 9999-9999</a></li>
        <li><a href="#">@amgproducoes</a></li>
      </ul>
    </div>
  </footer>
  <div class="footer-bottom">
    <span>© 2026 AMG Produções — Todos os direitos reservados</span>
    <span style="font-family:'Space Mono',monospace; font-size:0.65rem; color:var(--gold);">O FUTURO DOS EVENTOS</span>
  </div>

</div><script>
// ═══════════════════════════════
// CURSOR
// ═══════════════════════════════
const cur = document.getElementById('cursor');
const ring = document.getElementById('cursor-ring');
let mx = 0, my = 0, rx = 0, ry = 0;

document.addEventListener('mousemove', e => {
  mx = e.clientX; my = e.clientY;
  cur.style.left = mx + 'px'; cur.style.top = my + 'px';
});

function animRing() {
  rx += (mx - rx) * 0.12;
  ry += (my - ry) *.12;
  ring.style.left = rx + 'px'; ring.style.top = ry + 'px';
  requestAnimationFrame(animRing);
}
animRing();

document.querySelectorAll('a, button, .builder-opt, .universe-card, .cinema-card').forEach(el => {
  el.addEventListener('mouseenter', () => {
    cur.style.width = '20px'; cur.style.height = '20px';
    ring.style.width = '60px'; ring.style.height = '60px';
  });
  el.addEventListener('mouseleave', () => {
    cur.style.width = '10px'; cur.style.height = '10px';
    ring.style.width = '38px'; ring.style.height = '38px';
  });
});

// ═══════════════════════════════
// PARTICLES BG
// ═══════════════════════════════
const pCanvas = document.getElementById('particles-canvas');
const pCtx = pCanvas.getContext('2d');
let particles = [];

function resizeParticles() {
  pCanvas.width = window.innerWidth;
  pCanvas.height = window.innerHeight;
}
resizeParticles();
window.addEventListener('resize', resizeParticles);

for (let i = 0; i < 80; i++) {
  particles.push({
    x: Math.random() * window.innerWidth,
    y: Math.random() * window.innerHeight,
    r: Math.random() * 1.5 + 0.3,
    vx: (Math.random() - 0.5) * 0.3,
    vy: (Math.random() - 0.5) * 0.3,
    alpha: Math.random() * 0.4 + 0.1
  });
}

function animParticles() {
  pCtx.clearRect(0, 0, pCanvas.width, pCanvas.height);
  particles.forEach(p => {
    p.x += p.vx; p.y += p.vy;
    if (p.x < 0) p.x = pCanvas.width;
    if (p.x > pCanvas.width) p.x = 0;
    if (p.y < 0) p.y = pCanvas.height;
    if (p.y > pCanvas.height) p.y = 0;
    pCtx.beginPath();
    pCtx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
    pCtx.fillStyle = `rgba(201,168,76,${p.alpha})`;
    pCtx.fill();
  });
  requestAnimationFrame(animParticles);
}
animParticles();

// ═══════════════════════════════
// INTRO SEQUENCE
// ═══════════════════════════════
const logoReveal = document.getElementById('logo-reveal');
const introTagline = document.getElementById('intro-tagline');
const btnEnter = document.getElementById('btn-enter');

setTimeout(() => { logoReveal.classList.add('show'); }, 400);
setTimeout(() => {
  introTagline.style.opacity = '1';
  btnEnter.style.opacity = '1';
}, 1100);

btnEnter.addEventListener('click', () => {
  document.getElementById('intro').classList.add('out');
  setTimeout(() => {
    document.getElementById('intro').style.display = 'none';
    const site = document.getElementById('site');
    site.classList.add('visible');
    initThree();
    startAIAnimation();
  }, 1200);
});

// ═══════════════════════════════
// THREE.JS HERO SCENE
// ═══════════════════════════════
function initThree() {
  const canvas = document.getElementById('canvas-3d');
  if (!canvas || !window.THREE) return;

  const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
  renderer.setSize(canvas.offsetWidth, canvas.offsetHeight);
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(60, canvas.offsetWidth / canvas.offsetHeight, 0.1, 100);
  camera.position.set(0, 2, 8);

  const goldColor = 0xC9A84C;

  // Stage platform
  const stageGeo = new THREE.BoxGeometry(6, 0.15, 3);
  const stageMat = new THREE.MeshStandardMaterial({ color: 0x111108, metalness: 0.9, roughness: 0.3 });
  const stage = new THREE.Mesh(stageGeo, stageMat);
  stage.position.set(0, -1.5, 0);
  scene.add(stage);

  // Stage edge glow line
  const edgeGeo = new THREE.BoxGeometry(6.1, 0.03, 0.03);
  const edgeMat = new THREE.MeshBasicMaterial({ color: goldColor });
  const edge = new THREE.Mesh(edgeGeo, edgeMat);
  edge.position.set(0, -1.42, 1.5);
  scene.add(edge);

  // Light rigs
  const rigMat = new THREE.MeshStandardMaterial({ color: 0x1a1a1a, metalness: 0.95 });
  for (let i = -2.5; i <= 2.5; i += 1.25) {
    const rig = new THREE.Mesh(new THREE.CylinderGeometry(0.03, 0.03, 4), rigMat);
    rig.position.set(i, 0.5, -1.2);
    scene.add(rig);
    const lightHead = new THREE.Mesh(new THREE.SphereGeometry(0.1), new THREE.MeshBasicMaterial({ color: goldColor }));
    lightHead.position.set(i, -1, -1.2);
    scene.add(lightHead);
  }

  // Truss
  const truss = new THREE.Mesh(new THREE.BoxGeometry(6, 0.08, 0.08), new THREE.MeshStandardMaterial({ color: 0x333333, metalness: 0.8 }));
  truss.position.set(0, -1, -1.2);
  scene.add(truss);

  // Floating particles
  const geomPt = new THREE.BufferGeometry();
  const pts = [];
  for (let i = 0; i < 200; i++) {
    pts.push((Math.random() - 0.5) * 12, (Math.random() - 0.5) * 8, (Math.random() - 0.5) * 10);
  }
  geomPt.setAttribute('position', new THREE.Float32BufferAttribute(pts, 3));
  const matPt = new THREE.PointsMaterial({ color: goldColor, size: 0.04, transparent: true, opacity: 0.6 });
  scene.add(new THREE.Points(geomPt, matPt));

  // Lights
  scene.add(new THREE.AmbientLight(0x111111));
  const spotL = new THREE.SpotLight(0xC9A84C, 2, 15, Math.PI / 5);
  spotL.position.set(0, 4, 3);
  scene.add(spotL);
  const spotR = new THREE.SpotLight(0x8866ff, 0.5, 12, Math.PI / 6);
  spotR.position.set(3, 3, -1);
  scene.add(spotR);

  let t = 0;
  function animThree() {
    requestAnimationFrame(animThree);
    t += 0.008;
    camera.position.x = Math.sin(t * 0.3) * 1.5;
    camera.position.y = 2 + Math.sin(t * 0.2) * 0.3;
    camera.lookAt(0, -1, 0);
    matPt.opacity = 0.4 + Math.sin(t) * 0.2;
    renderer.render(scene, camera);
  }
  animThree();

  window.addEventListener('resize', () => {
    const w = canvas.offsetWidth, h = canvas.offsetHeight;
    renderer.setSize(w, h);
    camera.aspect = w / h;
    camera.updateProjectionMatrix();
  });
}

// ═══════════════════════════════
// SCROLL REVEAL
// ═══════════════════════════════
const revealEls = document.querySelectorAll('.reveal');
const io = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) { e.target.classList.add('visible'); }
  });
}, { threshold: 0.12 });
revealEls.forEach(el => io.observe(el));

// ═══════════════════════════════
// STAT COUNTER
// ═══════════════════════════════
const statEls = document.querySelectorAll('.stat-number[data-target]');
const sio = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      const el = e.target;
      const target = parseInt(el.getAttribute('data-target'));
      let current = 0;
      const step = target / 60;
      const timer = setInterval(() => {
        current = Math.min(current + step, target);
        el.textContent = Math.floor(current) + (el.closest('.stat-item')?.querySelector('.stat-label')?.textContent.includes('%') ? '%' : '+');
        if (current >= target) clearInterval(timer);
      }, 20);
      sio.unobserve(el);
    }
  });
}, { threshold: 0.5 });
statEls.forEach(el => sio.observe(el));

// ═══════════════════════════════
// AI CHAT ANIMATION
// ═══════════════════════════════
function startAIAnimation() {
  const msgs = ['cm1','cm2','cm3','cm4','cm5','cm6'];
  msgs.forEach((id, i) => {
    setTimeout(() => {
      const el = document.getElementById(id);
      if (el) el.classList.add('visible');
    }, i * 700);
  });
  setTimeout(() => {
    const card = document.getElementById('concept-card');
    if (card) card.classList.add('visible');
  }, msgs.length * 700 + 300);
}

const aio = new IntersectionObserver(entries => {
  if (entries[0].isIntersecting) { startAIAnimation(); aio.disconnect(); }
}, { threshold: 0.3 });
const aiChat = document.getElementById('ai-chat');
if (aiChat) aio.observe(aiChat);

// AI INPUT
const aiInput = document.getElementById('ai-input');
const aiSend = document.getElementById('ai-send');

function sendAIMessage() {
  const val = aiInput.value.trim();
  if (!val) return;
  const chat = document.getElementById('ai-chat');
  const inputRow = chat.querySelector('.ai-input-row');

  const userMsg = document.createElement('div');
  userMsg.className = 'chat-msg';
  userMsg.innerHTML = `<span class="msg-user">${val}</span>`;
  chat.insertBefore(userMsg, inputRow);
  setTimeout(() => userMsg.classList.add('visible'), 50);

  const responses = [
    { type: 'ai', text: 'Processando sua solicitação...' },
    { type: 'system', text: '▸ Analisando parâmetros de produção...' },
    { type: 'system', text: '▸ Mapeando soluções técnicas...' },
    { type: 'ai', text: 'Conceito pronto! Entre em contato para detalhes completos.' }
  ];

  responses.forEach((r, i) => {
    setTimeout(() => {
      const m = document.createElement('div');
      m.className = 'chat-msg';
      m.innerHTML = `<span class="msg-${r.type}">${r.text}</span>`;
      chat.insertBefore(m, inputRow);
      setTimeout(() => m.classList.add('visible'), 50);
      chat.scrollTop = chat.scrollHeight;
    }, (i + 1) * 600);
  });

  aiInput.value = '';
}

if (aiSend) aiSend.addEventListener('click', sendAIMessage);
if (aiInput) aiInput.addEventListener('keydown', e => { if (e.key === 'Enter') sendAIMessage(); });

// ═══════════════════════════════
// EVENT BUILDER
// ═══════════════════════════════
const builderState = { stage: 'medio', light: 'impactante', sound: 'gigante' };

const stageLabels = { pequeno: 'ÍNTIMO', medio: 'MÉDIO', grandioso: 'GRANDIOSO' };
const lightCounts = { elegante: 3, impactante: 5, festival: 8 };
const vibes = {
  'pequeno-elegante': 'Ambiente intimista · Luz suave · Som perfeito para 50–150 pessoas',
  'pequeno-impactante': 'Espaço menor, impacto máximo · Luzes focadas · Experiência intensa',
  'pequeno-festival': 'Show compacto · Energia de festival em espaço menor',
  'medio-elegante': 'Elegância sofisticada · Palco versátil · 100–300 convidados',
  'medio-impactante': 'Atmosfera poderosa · Som premium · Palco central com arcos laterais',
  'medio-festival': 'Festival de médio porte · Energia contagiante · Produção completa',
  'grandioso-elegante': 'Gala experience · Produção luxuosa · 300+ convidados em grande estilo',
  'grandioso-impactante': 'Evento de alto impacto · Estrutura completa · Referência no mercado',
  'grandioso-festival': '★ EXPERIÊNCIA TOTAL AMG ★ · Palco monumental · Som e luz de outro nível'
};

const estimates = {
  'pequeno': 'R$ 18.000 – R$ 45.000',
  'medio': 'R$ 45.000 – R$ 120.000',
  'grandioso': 'R$ 120.000 – R$ 500.000+'
};

document.querySelectorAll('.builder-opt').forEach(opt => {
  opt.addEventListener('click', () => {
    const group = opt.dataset.group;
    const val = opt.dataset.val;
    document.querySelectorAll(`.builder-opt[data-group="${group}"]`).forEach(o => o.classList.remove('selected'));
    opt.classList.add('selected');
    builderState[group] = val;
    updateBuilder();
  });
});

function updateBuilder() {
  const { stage, light, sound } = builderState;
  const key = `${stage}-${light}`;
  const vibe = vibes[key] || '';
  const lc = lightCounts[light];
  const stageEl = document.getElementById('preview-stage');
  const lightsEl = document.getElementById('preview-lights');
  const labelEl = document.getElementById('preview-label');
  const vibeEl = document.getElementById('preview-vibe');
  const estEl = document.getElementById('est-result');

  const stageWidths = { pequeno: '45%', medio: '65%', grandioso: '85%' };
  const stageHeights = { pequeno: '2rem', medio: '3rem', grandioso: '4.5rem' };
  if (stageEl) {
    stageEl.style.width = stageWidths[stage];
    stageEl.style.height = stageHeights[stage];
  }

  const lightColors = { elegante: 'rgba(240,240,200,0.8)', impactante: 'rgba(201,168,76,1)', festival: 'rgba(180,100,255,0.9)' };
  if (lightsEl) {
    lightsEl.innerHTML = '';
    for (let i = 0; i < lc; i++) {
      const d = document.createElement('div');
      d.className = 'plight';
      d.style.background = lightColors[light];
      d.style.boxShadow = `0 0 12px ${lightColors[light]}`;
      lightsEl.appendChild(d);
    }
  }

  if (labelEl) labelEl.textContent = `AMG STAGE — ${stageLabels[stage]}`;
  if (vibeEl) vibeEl.textContent = vibe;
  if (estEl) {
    estEl.innerHTML = `AMG ESTIMATE<br><span style="color:var(--gold); font-size:0.9rem;">${estimates[stage]}</span><br><span style="font-size:0.65rem; opacity:0.5;">Estimativa baseada na configuração atual · Sujeita a orçamento personalizado</span>`;
  }
}

// ═══════════════════════════════
// TRANSFORMADOR
// ═══════════════════════════════
const transformBtn = document.getElementById('transform-trigger');
let transformed = false;

if (transformBtn) {
  transformBtn.addEventListener('click', () => {
    if (transformed) {
      document.getElementById('after-content').classList.remove('reveal');
      document.querySelectorAll('.after-element').forEach(el => el.classList.remove('show'));
      transformBtn.textContent = '→ Ativar transformação';
      transformed = false;
    } else {
      const ac = document.getElementById('after-content');
      if (ac) ac.classList.add('reveal');
      document.querySelectorAll('.after-element').forEach((el, i) => {
        setTimeout(() => el.classList.add('show'), i * 120);
      });
      transformBtn.textContent = '↺ Reverter';
      transformed = true;
    }
  });
}

// Timeline scroll
const timelineItems = document.querySelectorAll('.timeline-item');
const tio = new IntersectionObserver(entries => {
  entries.forEach((e, i) => {
    if (e.isIntersecting) {
      setTimeout(() => e.target.classList.add('visible'), 150 * Array.from(timelineItems).indexOf(e.target));
    }
  });
}, { threshold: 0.2 });
timelineItems.forEach(el => tio.observe(el));
</script>
</body>
</html>
